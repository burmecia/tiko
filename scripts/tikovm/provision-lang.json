{
    "vm_id": "vm-1",
    "rootfs": {
        "path": "${ROOTFS}",
        "read_only_base": true
    },
    "resources": {
        "memory_mb": 1024,
        "vcpus": 2
    },
    "kernel": {
        "kernel_path": "$ASSETS/vmlinux-6.1",
        "kernel_cmdline": "console=ttyS0 reboot=k panic=1 pci=off systemd.unified_cgroup_hierarchy=0",
        "initrd_path": "$ASSETS/tiko-initramfs.cpio.gz"
    },
    "network": {},
    "manifest": {
        "version": 1,
        "workload": "lang-echo",
        "health": {
            "kind": "none"
        },
        "volumes": [
            {
                "name": "data",
                "tier": "local_fast",
                "mount_path": "/mnt/data",
                "size_mb": 64
            },
            {
                "name": "archive",
                "tier": "remote_slow",
                "mount_path": "/mnt/archive",
                "size_mb": 64,
                "source": "${REMOTE_SLOW_SOURCE}"
            }
        ]
    }
}
