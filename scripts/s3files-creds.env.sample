# Credentials for the S3 Files mount inside the Firecracker guest VM.
# IAM user: tiko-s3files-vm (least privilege: AmazonS3FilesClientFullAccess +
# bucket read). This file is gitignored (tikod/assets/*). Do not commit.
S3FILES_AWS_ACCESS_KEY_ID=<aws_access_key_id>
S3FILES_AWS_SECRET_ACCESS_KEY=<aws_secret_access_key>
